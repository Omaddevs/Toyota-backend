# --- Nusxa: cp .env.example .env  keyin MYSQL_PASSWORD ni to'ldiring ---
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# MySQL Workbench (127.0.0.1:3306) — shu qatorlarni .env da oching va parolni yozing.
# Avval MySQL da baza yarating: CREATE DATABASE toymakon CHARACTER SET utf8mb4;
# MUHIM: MySQL ishlatayotganingizda DATABASE_URL va POSTGRES_* bo'lmasin (kommentda qoling).
MYSQL_DATABASE=toymakon
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Production xavfsizlik (DJANGO_DEBUG=0 bo'lganda)
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=0
# DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# --- PostgreSQL / DATABASE_URL (MySQL emas, boshqa vaqt uchun) ---
# POSTGRES_DB=toymakon
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=parolingiz
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_SSL_REQUIRE=1
